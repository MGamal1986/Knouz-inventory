# Copy this file to .env and fill in your own values before running docker compose

# PostgreSQL
DB_USER=knouz
DB_PASSWORD=change_me_locally
DB_NAME=knouz_inventory

# API
JWT_SECRET=change_me_to_a_long_random_string
# Optional: separate secret for refresh tokens. Falls back to JWT_SECRET if unset.
JWT_REFRESH_SECRET=change_me_to_a_different_long_random_string
PORT=4000

# Frontend — the Vite dev server proxies /api, /uploads, /invoices to this
# target so the browser only ever talks to one origin (required for the
# httpOnly auth cookies to be sent). Use the docker-compose service name
# when running via docker compose, localhost when running `npm run dev` directly.
VITE_API_PROXY_TARGET=http://localhost:4000
