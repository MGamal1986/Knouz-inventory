generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  passwordHash String
  fullName     String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Category {
  id             Int       @id @default(autoincrement())
  name           String    @unique
  baseCode       String    @unique
  codeRangeStart Int
  codeRangeEnd   Int
  lastSeq        Int       @default(0)
  products       Product[]
  createdAt      DateTime  @default(now())
}

model Supplier {
  id        Int       @id @default(autoincrement())
  name      String
  phone     String?
  address   String?
  products  Product[]
  createdAt DateTime  @default(now())
}

enum ProductStatus {
  IN_STOCK
  SOLD
  PARTIALLY_SOLD
}

enum DiscountType {
  NONE
  PERCENTAGE
  FIXED
}

model Product {
  id              Int           @id @default(autoincrement())
  productCode     String        @unique
  description     String
  categoryId      Int
  category        Category      @relation(fields: [categoryId], references: [id])
  supplierId      Int
  supplier        Supplier      @relation(fields: [supplierId], references: [id])
  purchaseDate    DateTime
  originalCost    Decimal       @db.Decimal(10, 2)
  profitPercent   Decimal       @db.Decimal(5, 2)
  sellingPrice    Decimal       @db.Decimal(10, 2)
  discountType    DiscountType  @default(NONE)
  discountValue   Decimal       @default(0) @db.Decimal(10, 2)
  quantity        Int
  quantitySold    Int           @default(0)
  invoiceImageUrl String?
  status          ProductStatus @default(IN_STOCK)
  saleItems       SaleItem[]
  deletedAt       DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model Client {
  id        Int      @id @default(autoincrement())
  name      String
  address   String?
  mobile    String
  sales     Sale[]
  createdAt DateTime @default(now())
}

model Sale {
  id            Int        @id @default(autoincrement())
  invoiceNumber String     @unique
  clientId      Int
  client        Client     @relation(fields: [clientId], references: [id])
  items         SaleItem[]
  totalAmount   Decimal    @db.Decimal(10, 2)
  invoicePdfUrl String?
  createdAt     DateTime   @default(now())
}

model SaleItem {
  id                Int          @id @default(autoincrement())
  saleId            Int
  sale              Sale         @relation(fields: [saleId], references: [id])
  productId         Int
  product           Product      @relation(fields: [productId], references: [id])
  quantity          Int
  originalUnitPrice Decimal      @db.Decimal(10, 2)
  discountType      DiscountType @default(NONE)
  discountValue     Decimal      @default(0) @db.Decimal(10, 2)
  discountAmount    Decimal      @default(0) @db.Decimal(10, 2)
  unitPrice         Decimal      @db.Decimal(10, 2)
  lineTotal         Decimal      @db.Decimal(10, 2)
  refundedQuantity  Int          @default(0)
  refunds           Refund[]
}

model Refund {
  id           Int      @id @default(autoincrement())
  saleItemId   Int
  saleItem     SaleItem @relation(fields: [saleItemId], references: [id])
  quantity     Int
  refundAmount Decimal  @db.Decimal(10, 2)
  reason       String?
  createdAt    DateTime @default(now())
}

enum CapitalMovementType {
  INITIAL  // Opening balance the business started with
  SALE     // A sale increases capital by its net total
  REFUND   // A refund rolls back the amount a sale had added
  PURCHASE // A new product bought "from capital"
  RESTOCK  // A restock batch bought "from capital"
}

// Append-only ledger of every change to the business's working capital.
// The current capital balance is the signed sum of every movement's `amount`
// (positive = money in, negative = money out). Kept as a ledger rather than a
// single mutable number so the balance is always auditable and reconstructable,
// and so restocks — which keep no other history — can be traced.
model CapitalMovement {
  id          Int                 @id @default(autoincrement())
  type        CapitalMovementType
  amount      Decimal             @db.Decimal(10, 2)
  description String?
  saleId      Int?
  productId   Int?
  createdAt   DateTime            @default(now())

  @@index([createdAt])
}
